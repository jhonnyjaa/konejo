{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Konejo default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write",
    "fs:allow-appdata-meta-recursive",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load",
    "store:allow-delete",
    "store:allow-entries",
    "store:allow-keys",
    "log:default",
    "log:allow-log"
  ]
}
